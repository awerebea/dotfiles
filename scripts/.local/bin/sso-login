#!/usr/bin/env bash

VALID_ENVS=(
    "all"
    bright_sso_{admin,devops,buildsecurityprovisioning}
)

_check_inputs() {
    if ! command -v aws &>/dev/null; then
        echo "AWS CLI is not installed." >&2
        exit 1
    fi

    if [ "$#" -lt 1 ]; then
        printf "The desired AWS profile(s) must be passed as arguments.\n" >&2
        exit 1
    fi
}

_is_valid_env() {
    local candidate="$1" valid
    for valid in "${VALID_ENVS[@]}"; do
        [[ "$candidate" == "$valid" ]] && return 0
    done
    return 1
}

_get_envs() {
    local -a envs_raw=()
    local arg
    for arg in "$@"; do
        while IFS= read -r line; do
            envs_raw+=("$line")
        done < <(echo "$arg" | tr ";,/" "\n")
    done

    # Remove duplicates
    local -A seen
    local -a envs=()
    local element
    for element in "${envs_raw[@]}"; do
        if [[ -z "${seen[$element]}" ]]; then
            envs+=("$element")
            seen["$element"]=1
        fi
    done

    local env
    for env in "${envs[@]}"; do
        if ! _is_valid_env "$env"; then
            echo "Invalid environment passed: $env" >&2
            exit 1
        fi
        if [ "$env" = "all" ]; then
            envs=("${VALID_ENVS[@]}")
            break
        fi
    done

    # Remove "all" from the final list by value, not by index
    local -a filtered=()
    for env in "${envs[@]}"; do
        [ "$env" = "all" ] && continue
        filtered+=("$env")
    done
    envs=("${filtered[@]}")

    for env in "${envs[@]}"; do
        echo "$env"
    done
}

_main() {
    _check_inputs "$@"

    local -a envs=()
    local line
    while IFS= read -r line; do
        envs+=("$line")
    done < <(_get_envs "$@")

    # Clear existing credentials to refresh SSO tokens NOTE: not sure if we actually need it
    # rm -rf ~/.aws/{cli,sso}

    local env
    for env in "${envs[@]}"; do
        local output url code status
        output=$(aws sso login --profile="$env" 2>&1)
        status=$?
        if [ "$status" -ne 0 ]; then
            echo "Failed to start SSO login for profile '$env':" >&2
            printf '%s\n' "$output" >&2
            continue
        fi

        url=$(printf '%s\n' "$output" | grep -E '^https://')
        code=$(printf '%s\n' "$output" | grep -E '^[A-Z0-9]{4}-[A-Z0-9]{4}$')

        if [ -z "$url" ] || [ -z "$code" ]; then
            echo "Could not find login URL/code for profile '$env'. Output was:" >&2
            printf '%s\n' "$output" >&2
            continue
        fi

        echo "${url}?user_code=${code}"
    done
}

# Start program here
_main "$@"
