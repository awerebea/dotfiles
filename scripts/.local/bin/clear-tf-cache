#! /usr/bin/env bash

if command -v fd &>/dev/null; then
    paths=$(
        {
            fd -IH -td '\.terragrunt-cache|\.terraform$'
            fd -IH -tf '\.terraform\.lock\.hcl$'
        } | sort
    )
else
    paths=$(
        find . \( -type d -name '.terragrunt-cache' -exec printf '%s/\n' {} + \) \
            -o \( -type d -name '.terraform' -exec printf '%s/\n' {} + \) \
            -o \( -type f -name '.terraform.lock.hcl' -print \) |
            sort
    )
fi

if [ -n "$paths" ]; then
    printf '%s\n' "$paths"
    printf '%s\n' "$paths" | xargs rm -rf
fi
