#! /usr/bin/env bash

usage() {
    cat <<'EOF'
Usage: clear-tf-cache [-f|--force] [-n|--dry-run]

Remove .terraform and .terragrunt-cache directories, and
.terraform.lock.hcl files, found under the current directory.

By default, a matching path is only removed if it is both:
  - inside a git worktree, and
  - covered by .gitignore (i.e. not intentionally tracked)
Paths that don't meet these criteria are skipped, with a warning
explaining why.

Options:
  -f, --force     Remove matching paths regardless of git-worktree or
                  .gitignore status
  -d, --dry-run   Show what would be removed and the space that would
                  be reclaimed, without deleting anything
  -h, --help      Show this help message
EOF
}

# Expand squashed short options (-fd -> -f -d) into separate tokens so the
# parsing loop below can handle them one at a time, same as `ls -la`.
expanded=()
while [ $# -gt 0 ]; do
    case "$1" in
    --*)
        expanded+=("$1")
        ;;
    -?*)
        if [ "${#1}" -gt 2 ]; then
            chars="${1#-}"
            for ((i = 0; i < ${#chars}; i++)); do
                expanded+=("-${chars:i:1}")
            done
        else
            expanded+=("$1")
        fi
        ;;
    *)
        expanded+=("$1")
        ;;
    esac
    shift
done
set -- "${expanded[@]}"

force=0
dry_run=0
while [ $# -gt 0 ]; do
    case "$1" in
    -f | --force)
        force=1
        shift
        ;;
    -d | --dry-run)
        dry_run=1
        shift
        ;;
    -h | --help)
        usage
        exit 0
        ;;
    *)
        echo "clear-tf-cache: unknown option '$1'" >&2
        exit 1
        ;;
    esac
done

# Converts a size in KB (as reported by `du -sk`) into a human-readable
# string, scaling up through KB/MB/GB/TB/PB as appropriate.
human_size() {
    awk -v kb="$1" 'BEGIN {
        split("KB MB GB TB PB", units, " ")
        i = 1
        value = kb + 0
        while (value >= 1024 && i < 5) {
            value /= 1024
            i++
        }
        printf "%.2f %s", value, units[i]
    }'
}

path_size_kb() {
    du -sk -- "$1" 2>/dev/null | awk '{print $1}'
}

paths=()

if command -v fd &>/dev/null; then
    while IFS= read -r -d '' path; do
        paths+=("$path")
    done < <(fd -0 -HI -td '\.terragrunt-cache|\.terraform$')

    while IFS= read -r -d '' path; do
        paths+=("$path")
    done < <(fd -0 -HI -tf '\.terraform\.lock\.hcl$')
else
    while IFS= read -r -d '' path; do
        paths+=("$path")
    done < <(
        find . \( -type d -name '.terragrunt-cache' -exec printf '%s/\0' {} + \) \
            -o \( -type d -name '.terraform' -exec printf '%s/\0' {} + \) \
            -o \( -type f -name '.terraform.lock.hcl' -print0 \)
    )
fi

if [ "${#paths[@]}" -eq 0 ]; then
    exit 0
fi

sorted=()
while IFS= read -r path; do
    sorted+=("$path")
done < <(printf '%s\n' "${paths[@]}" | sort)
paths=("${sorted[@]}")

to_remove=()
total_kb=0

for path in "${paths[@]}"; do
    size_kb=$(path_size_kb "$path")
    [ -z "$size_kb" ] && size_kb=0
    size_human=$(human_size "$size_kb")

    keep=1
    reason=""
    if [ "$force" -eq 0 ]; then
        path_dir=$(dirname -- "$path")
        path_base=$(basename -- "$path")
        # -C scopes git to the repo containing this specific path, so this
        # works when the current directory holds multiple unrelated clones
        # rather than a single git worktree.
        if ! command -v git &>/dev/null || ! git -C "$path_dir" rev-parse --is-inside-work-tree &>/dev/null; then
            keep=0
            reason="outside git-worktree"
        elif ! git -C "$path_dir" check-ignore -q -- "$path_base"; then
            keep=0
            reason="not Git-ignored"
        fi
    fi

    if [ "$keep" -eq 1 ]; then
        to_remove+=("$path")
        total_kb=$((total_kb + size_kb))
        echo "$path ($size_human)"
    else
        echo "WARNING: Skipped ($reason): $path ($size_human)"
    fi
done

total_human=$(human_size "$total_kb")

if [ "$dry_run" -eq 1 ]; then
    echo "Would reclaim: $total_human"
else
    if [ "${#to_remove[@]}" -gt 0 ]; then
        rm -rf -- "${to_remove[@]}"
    fi
    echo "Reclaimed: $total_human"
fi
