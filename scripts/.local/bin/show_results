#! /usr/bin/env bash

g_envs_pattern=""
g_positional_args+=("$1")
g_output=false
g_error=false
g_plan=false
g_apply=false

VALID_ENVS=(
    prdev
    dev
    test
    qa
    stage
    prod
    shared
    audit
)

# Define colors
COLOR_RED='\e[1;31m' # Red
NO_COLOR='\e[0m'     # No Color

__join_by() {
    local d f
    d="${1-}" f="${2-}"
    if shift 2; then
        printf %s "$f" "${@/#/$d}"
    fi
}

_process_cmd_options() {
    # Short options that require a value (none currently). Used by the
    # squash-expansion below to stop mid-token once one of these is hit: a
    # value-taking short option consumes the rest of its token (or the next
    # argv item, if nothing is left) as its value, and nothing after it is
    # treated as more flags -- same GNU/POSIX convention as `tar -xvf file`
    # (note -f must come last).
    local value_opts=""

    # Expand squashed short options (-pa -> -p -a) into separate tokens so
    # the parsing loop below can handle them one at a time, same as `ls -la`.
    local expanded=() chars i c rest
    while [ $# -gt 0 ]; do
        case "$1" in
        --*)
            expanded+=("$1")
            ;;
        -?*)
            if [ "${#1}" -gt 2 ]; then
                chars="${1#-}"
                for ((i = 0; i < ${#chars}; i++)); do
                    c="${chars:i:1}"
                    expanded+=("-$c")
                    case "$value_opts" in
                    *"$c"*)
                        rest="${chars:i+1}"
                        [ -n "$rest" ] && expanded+=("$rest")
                        break
                        ;;
                    esac
                done
            else
                expanded+=("$1")
            fi
            ;;
        *)
            expanded+=("$1")
            ;;
        esac
        shift
    done
    set -- "${expanded[@]}"

    while [[ -n "$1" ]]; do
        case "$1" in
        "-p" | "--plan")
            g_plan=true
            ;;
        "-a" | "--apply")
            g_apply=true
            ;;
        "-o" | "--out" | "--output" | "--outputs")
            g_output=true
            ;;
        "-e" | "--err" | "--error" | "--errors")
            g_error=true
            ;;
        *)
            g_positional_args+=("$1")
            ;;
        esac
        shift
    done

    g_envs_raw=()
    for ((i = 0; i < ${#g_positional_args[@]}; i++)); do
        read -ra splitted_arg <<<"$(echo "${g_positional_args[i]}" | tr ";,/" " ")"
        g_envs_raw+=("${splitted_arg[@]}")
    done

    # Remove duplicates
    declare -A g_seen_elements
    g_envs=()
    for element in "${g_envs_raw[@]}"; do
        if [ "${g_seen_elements[$element]}" = "" ]; then
            g_envs+=("$element")
            g_seen_elements["$element"]=1
        fi
    done

    for env_name in "${g_envs[@]}"; do
        if [[ ! "${VALID_ENVS[*]}" =~ $env_name ]]; then
            echo -e "${COLOR_RED}ERROR:${NO_COLOR} Invalid environment passed."
            exit 1
        fi
    done
    if [ "${#g_envs[@]}" -gt 1 ]; then
        g_envs_pattern="{$(__join_by ',' "${g_envs[@]}")}"
    elif [ "${#g_envs[@]}" -eq 1 ]; then
        g_envs_pattern="${g_envs[0]}"
    fi
}

# Main
_main() {
    local results pattern commands subdirs
    _process_cmd_options "$@"
    if [ "$g_envs_pattern" == "" ]; then
        g_envs_pattern="{$(__join_by ',' "${VALID_ENVS[@]}")}"
    fi

    results=()
    "$g_output" && results+=("output")
    "$g_error" && results+=("error")

    pattern="(output|error)\.txt"
    if [ "${#results[@]}" -gt 1 ]; then
        pattern="($(__join_by '|' "${results[@]}"))\.txt"
    elif [ "${#results[@]}" -eq 1 ]; then
        pattern="${results[0]}\.txt"
    fi

    commands=()
    "$g_plan" && commands+=("plan")
    "$g_apply" && commands+=("apply")

    subdirs=""
    if [ "${#commands[@]}" -gt 1 ]; then
        subdirs="{$(__join_by ',' "${commands[@]}")}"
    elif [ "${#commands[@]}" -eq 1 ]; then
        subdirs="${commands[0]}"
    fi

    if command -v fd &>/dev/null; then
        eval "fd -IH -tf \"$pattern\" ./result/$g_envs_pattern/$subdirs 2>/dev/null | \
            sort | xargs tail -v -n +1 | less -NRWr --use-color"
    else
        # Use parameter expansion to escape "(", ")" and "|"
        pattern="${pattern//(/\\(}"
        pattern="${pattern//)/\\)}"
        pattern="${pattern//|/\\|}"
        eval "find ./result/$g_envs_pattern/$subdirs -type f -regex \".*$pattern\" 2>/dev/null | \
            sort | xargs tail -v -n +1 | less -NRWr --use-color"
    fi
}

_main "$@"
